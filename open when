<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Our Journey</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- Background music -->
<audio id="bg-music" loop>
  <source src="music.mp3" type="audio/mpeg">
</audio>

<button id="music-toggle">🔊</button>

<div class="container">

  <h1 class="title">a journey written in stars</h1>

  <div class="stars">

    <!-- 10 stars -->
    <div class="star" data-id="0" style="top:10%; left:50%;">✦</div>
    <div class="star" data-id="1" style="top:20%; left:70%;">✦</div>
    <div class="star" data-id="2" style="top:35%; left:85%;">✦</div>
    <div class="star" data-id="3" style="top:55%; left:80%;">✦</div>
    <div class="star" data-id="4" style="top:70%; left:65%;">✦</div>
    <div class="star" data-id="5" style="top:80%; left:50%;">✦</div>
    <div class="star" data-id="6" style="top:70%; left:35%;">✦</div>
    <div class="star" data-id="7" style="top:55%; left:20%;">✦</div>
    <div class="star" data-id="8" style="top:35%; left:15%;">✦</div>
    <div class="star" data-id="9" style="top:20%; left:30%;">✦</div>

  </div>

  <!-- Popup -->
  <div id="popup" class="hidden">
    <div class="popup-content">
      <span id="close">✕</span>
      <h2 id="popup-title"></h2>
      <p id="popup-text"></p>
    </div>
  </div>

  <!-- Final message -->
  <div id="final-message" class="hidden">
    <h2>now you see it.<br>this was always us.</h2>
  </div>

</div>

<script src="script.js"></script>
</body>
</html>

body {
  margin: 0;
  font-family: sans-serif;
  background: radial-gradient(circle at center, #0b0c2a, #000);
  color: white;
  overflow-x: hidden;
}

.title {
  text-align: center;
  margin-top: 40px;
  font-size: 24px;
  opacity: 0.8;
}

.stars {
  position: relative;
  height: 100vh;
}

.star {
  position: absolute;
  cursor: pointer;
  font-size: 18px;
  opacity: 0.5;
  transition: 0.3s;
}

.star:hover {
  transform: scale(1.5);
  opacity: 1;
}

.star.opened {
  color: #ffb6d9;
  opacity: 1;
  text-shadow: 0 0 10px #ffb6d9;
}

#popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.7);
  display: flex;
  justify-content: center;
  align-items: center;
}

.hidden {
  display: none;
}

.popup-content {
  background: rgba(20,20,40,0.9);
  padding: 20px;
  border-radius: 12px;
  max-width: 90%;
}

#close {
  float: right;
  cursor: pointer;
}

#final-message {
  position: fixed;
  top: 40%;
  width: 100%;
  text-align: center;
  font-size: 28px;
  color: #ffb6d9;
  text-shadow: 0 0 15px #ffb6d9;
}

#music-toggle {
  position: fixed;
  top: 10px;
  right: 10px;
}

const stars = document.querySelectorAll(".star");
const popup = document.getElementById("popup");
const title = document.getElementById("popup-title");
const text = document.getElementById("popup-text");
const closeBtn = document.getElementById("close");
const finalMessage = document.getElementById("final-message");
const music = document.getElementById("bg-music");
const musicToggle = document.getElementById("music-toggle");

let openedStars = [];

const letters = [
  {title:"Open when you miss me", text:"Even when I’m not around, I’m still there in small ways..."},
  {title:"Open when you think of how we started", text:"We didn’t know then how far we’d come..."},
  {title:"Open when we fight", text:"We’ve had our moments, but we always find our way back..."},
  {title:"Open when you feel I don’t understand you", text:"Maybe I don’t always say it right, but I try..."},
  {title:"Open when you feel lost", text:"You’ve found your way before, you will again..."},
  {title:"Open when you feel like giving up", text:"You’re stronger than this moment..."},
  {title:"Open when you doubt yourself", text:"I see things in you that you don’t see..."},
  {title:"Open when you achieve something big", text:"I’m proud of you, always..."},
  {title:"Open when you think about us long term", text:"We’ve built something real..."},
  {title:"Open when you read this years later", text:"If you’re here, it means we mattered..."}
];

stars.forEach(star => {
  star.addEventListener("click", () => {
    const id = star.dataset.id;

    title.innerText = letters[id].title;
    text.innerText = letters[id].text;

    popup.classList.remove("hidden");

    if (!openedStars.includes(id)) {
      openedStars.push(id);
      star.classList.add("opened");
    }

    if (openedStars.length === stars.length) {
      setTimeout(() => {
        finalMessage.classList.remove("hidden");
      }, 800);
    }
  });
});

closeBtn.onclick = () => popup.classList.add("hidden");

// music toggle
musicToggle.onclick = () => {
  if (music.paused) {
    music.play();
    musicToggle.innerText = "🔊";
  } else {
    music.pause();
    musicToggle.innerText = "🔇";
  }
};

